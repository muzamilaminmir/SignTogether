    <string name="mission_title">Our Mission</string>
    <string name="mission_text">SignTogether bridges communication gaps by providing instant translation between speech and sign language, empowering deaf and speech-impaired users with accessible, inclusive technology.</string>
    <string name="purpose_title">Our Purpose</string>
    <string name="purpose_text">We believe everyone deserves to communicate freely and safely. Our emergency contact feature ensures quick assistance when it matters most.</string>

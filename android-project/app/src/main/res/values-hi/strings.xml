    <string name="mission_title">हमारा मिशन</string>
    <string name="mission_text">SignTogether भाषण और सांकेतिक भाषा के बीच त्वरित अनुवाद प्रदान करता है, मूक और बधिर उपयोगकर्ताओं को सशक्त बनाता है।</string>
    <string name="purpose_title">हमारा उद्देश्य</string>
    <string name="purpose_text">हमारा मानना ​​है कि हर किसी को स्वतंत्र रूप से संवाद करने का अधिकार है। हमारी आपातकालीन संपर्क सुविधा त्वरित सहायता सुनिश्चित करती है।</string>
    <string name="team_unity_title">टीम यूनिटी</string>
    <string name="team_unity_text">यह एप्लिकेशन टीम यूनिटी द्वारा बनाया गया है। साथ मिलकर, हम दुनिया को अधिक सुलभ बना रहे हैं।</string>


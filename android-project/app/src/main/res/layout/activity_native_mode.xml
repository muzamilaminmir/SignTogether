<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Avatar WebView -->
    <WebView
        android:id="@+id/avatarWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Video Dictionary Overlay (Placed behind bottom panel) -->
    <FrameLayout
        android:id="@+id/videoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#111827"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Realistic Avatar Placeholder -->
        <ImageView
            android:id="@+id/avatarPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@drawable/avatar_real"
            android:visibility="visible" />

        <VideoView
            android:id="@+id/videoPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>
            
        <TextView
            android:id="@+id/videoStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_ready_to_sign"
            android:textColor="#FFFFFF"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="32dp"
            android:textSize="18sp"/>
    </FrameLayout>

    <!-- Top Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/detectedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_waiting"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/confidenceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_confidence"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnSwitchCamera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_switch_cam"
                android:textSize="12sp"
                android:backgroundTint="#555555"
                android:layout_marginEnd="16dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Robot Panel -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/fullSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#000000"
            android:textSize="18sp"
            android:minLines="2"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <!-- Robot Avatar -->
            <ImageView
                android:id="@+id/robotAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/idle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/robotState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_idle"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"/>

                <TextView
                    android:id="@+id/robotMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/robot_ready"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>
            
            <!-- Mic Button -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_btn_speak_now"
                android:backgroundTint="@color/secondary"
                app:tint="#FFFFFF"
                app:fabSize="mini" />
        </LinearLayout>

        <!-- Text Input Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/inputField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_type_robot"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA"
                android:background="#F0F0F0"
                android:padding="10dp"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_send"
                android:layout_marginStart="8dp"/>
                
            <Button
                android:id="@+id/btnSpeak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_speak"
                android:backgroundTint="@color/highlight"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
